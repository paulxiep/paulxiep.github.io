---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { demos, getDemoUrl } from '../../data/demos';

export function getStaticPaths() {
	return demos.map((demo) => ({
		params: { slug: demo.slug },
		props: demo,
	}));
}

const { title, slug } = Astro.props;
const iframeUrl = getDemoUrl(Astro.props);
---

<html lang="en">
	<head>
		<BaseHead title={title} description={`Demo: ${title}`} />
		<style>
			html, body {
				height: 100%;
				margin: 0;
				overflow: hidden;
			}
			body {
				display: flex;
				flex-direction: column;
			}
			main {
				flex: 1;
				width: 100%;
				margin: 0;
				padding: 0;
			}
			iframe {
				width: 100%;
				height: 100%;
				border: none;
				display: block;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<iframe src={iframeUrl} title={title}></iframe>
		</main>
		<Footer />
	</body>
</html>
