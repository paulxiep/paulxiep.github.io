---
import { Image } from 'astro:assets';
import FormattedDate from './FormattedDate.astro';
import categoryMapping from '../data/category-mapping.json';

interface Props {
	posts: Array<{
		id: string;
		data: {
			title: string;
			description?: string;
			pubDate: Date;
			heroImage?: ImageMetadata;
			tags?: string[];
		};
	}>;
}

const { posts } = Astro.props;
const tagLabels = categoryMapping.tagLabels as Record<string, string>;
---

<ul>
	{
		posts.map((post) => (
			<li data-tags={post.data.tags?.join(',') || ''}>
				<a href={`/blog/${post.id}/`}>
					{post.data.heroImage && (
						<Image width={720} height={360} src={post.data.heroImage} alt="" />
					)}
					<h4 class="title">{post.data.title}</h4>
					{post.data.description && (
						<p class="description">{post.data.description}</p>
					)}
					<p class="date">
						<FormattedDate date={post.data.pubDate} />
					</p>
				</a>
				{post.data.tags && post.data.tags.length > 0 && (
					<div class="tags">
						{post.data.tags.map((tag) => (
							<a href={`/blog/tags/${tag}/`} class="tag">
								{tagLabels[tag] || tag}
							</a>
						))}
					</div>
				)}
			</li>
		))
	}
</ul>

<style>
	ul {
		display: flex;
		flex-wrap: wrap;
		gap: 2rem;
		list-style-type: none;
		margin: 0;
		padding: 0;
	}
	ul li {
		width: calc(50% - 1rem);
	}
	ul li * {
		text-decoration: none;
		transition: 0.2s ease;
	}
	ul li img {
		margin-bottom: 0.5rem;
		border-radius: 12px;
	}
	ul li a {
		display: block;
	}
	.title {
		margin: 0;
		color: rgb(var(--black));
		line-height: 1;
	}
	.description {
		margin: 0.2em 0 0;
		color: rgb(var(--gray));
		font-size: 0.9em;
	}
	.date {
		margin: 0;
		color: rgb(var(--gray));
	}
	ul li a:hover h4,
	ul li a:hover .date {
		color: rgb(var(--accent));
	}
	ul a:hover img {
		box-shadow: var(--box-shadow);
	}
	.tags {
		display: flex;
		gap: 0.4em;
		flex-wrap: wrap;
		margin-top: 0.5em;
	}
	@media (max-width: 720px) {
		ul {
			gap: 0.5em;
		}
		ul li {
			width: 100%;
			text-align: center;
		}
		.tags {
			justify-content: center;
		}
	}
</style>
