---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { projectSchema } from '../lib/schema';

type Props =
	| CollectionEntry<'projects'>['data']
	| CollectionEntry<'externalProjects'>['data'];

const { title, description, tags } = Astro.props;
const repo = 'repo' in Astro.props ? Astro.props.repo : undefined;
const demoUrl = 'demoUrl' in Astro.props ? Astro.props.demoUrl : undefined;
const heroImage = 'heroImage' in Astro.props ? Astro.props.heroImage : undefined;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const heroImageURL = heroImage ? new URL(heroImage.src, Astro.site) : undefined;
const jsonLd = projectSchema({
	url: canonicalURL,
	title,
	description,
	repo,
	demoUrl,
	image: heroImageURL,
	keywords: tags,
});
---

<html lang="en">
	<head>
		<BaseHead
			title={title}
			description={description}
			image={heroImage}
			jsonLd={jsonLd}
		/>
		<style>
			main {
				width: calc(100% - 2em);
				max-width: 100%;
				margin: 0;
			}
			.prose {
				max-width: min(1080px, calc(100% - 2em));
				margin: auto;
				padding: 1em;
				color: rgb(var(--gray-dark));
			}
			.title {
				margin-bottom: 1em;
				padding: 1em 0;
				text-align: center;
				line-height: 1;
			}
			.title h1 {
				margin: 0 0 0.5em 0;
			}
			.meta {
				color: rgb(var(--gray));
				margin-bottom: 0.5em;
			}
			.meta a {
				color: var(--accent);
			}
			.tags {
				display: flex;
				gap: 0.5em;
				justify-content: center;
				flex-wrap: wrap;
				margin-top: 0.5em;
			}
			.tag {
				background: rgb(var(--gray-light));
				color: rgb(var(--gray-dark));
				padding: 0.2em 0.6em;
				border-radius: 4px;
				font-size: 0.85em;
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				<div class="prose">
					<div class="title">
						<h1>{title}</h1>
						<p>{description}</p>
						{repo && <p class="meta"><a href={repo} target="_blank">View on GitHub</a></p>}
						{tags.length > 0 && (
							<div class="tags">
								{tags.map((tag) => <span class="tag">{tag}</span>)}
							</div>
						)}
						<hr />
					</div>
					<slot />
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
