---
const today = new Date();
---

<footer>
	<span class="copy">&copy; {today.getFullYear()} Paul X. All rights reserved.</span>
	<span class="legal-links">
		<a href="/privacy/">Privacy Policy</a>
		<a href="/terms/">Terms of Service</a>
	</span>
</footer>
<style>
	footer {
		display: flex;
		flex-wrap: wrap;
		justify-content: center;
		align-items: baseline;
		gap: 0.4em 1.25em;
		padding: 0.5em 1em;
		background: rgb(var(--surface));
		color: rgb(var(--gray));
		text-align: center;
		font-size: 0.875em;
		line-height: 1.4;
		position: fixed;
		bottom: 0;
		left: 0;
		right: 0;
		z-index: 10;
		box-shadow: 0 -2px 8px rgba(var(--black), 5%);
	}
	.legal-links {
		display: inline-flex;
		gap: 1.25em;
	}
	.legal-links a {
		color: rgb(var(--gray));
		text-decoration: none;
	}
	.legal-links a:hover {
		color: rgb(var(--gray-dark));
	}
	@media (max-width: 600px) {
		footer {
			flex-direction: column;
			gap: 0.35em;
			padding: 0.75em 1em;
		}
	}
</style>
