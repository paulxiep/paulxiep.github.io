---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { personSchema, websiteSchema } from '../lib/schema';

const posts = (await getCollection('blog'))
	.filter((p) => !p.data.draft && p.data.featured)
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const externalProjectsAll = await getCollection('externalProjects');
const projects = [
	...(await getCollection('projects')),
	...externalProjectsAll,
]
	.filter((p) => p.data.featured)
	.sort((a, b) => a.data.sortOrder - b.data.sortOrder)
	.slice(0, 3);

const iframeDemos = new Set((await getCollection('demos')).map((d) => d.id));
const externalDemoUrl = new Map(
	externalProjectsAll.map((p) => [p.id, p.data.demoUrl]),
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title={SITE_TITLE}
			description={SITE_DESCRIPTION}
			jsonLd={[websiteSchema, personSchema]}
		/>
		<style>
			.hero {
				text-align: center;
				padding: 2em 0;
			}
			.hero h1 {
				margin-bottom: 0.25em;
			}
			.hero p {
				color: rgb(var(--gray));
				font-size: 1.1em;
			}
			section {
				margin-bottom: 3em;
			}
			section h2 {
				border-bottom: 1px solid rgb(var(--gray-light));
				padding-bottom: 0.3em;
				margin-bottom: 1em;
			}
			.see-all {
				display: inline-block;
				margin-top: 0.5em;
				font-size: 0.9em;
			}
			ul {
				display: flex;
				flex-wrap: wrap;
				gap: 2rem;
				list-style: none;
				padding: 0;
				margin: 0;
			}
			ul li {
				width: calc(50% - 1rem);
			}
			@media (max-width: 720px) {
				ul li {
					width: 100%;
				}
			}
			ul li a {
				text-decoration: none;
			}
			.project-header {
				display: flex;
				align-items: baseline;
				gap: 0.5em;
			}
			.dot-sep {
				color: rgb(var(--gray));
			}
			ul li .demo-link {
				color: var(--accent);
				text-decoration: underline;
				font-size: 1.1em;
			}
			.demo-link:hover {
				opacity: 0.8;
			}
			.post-title, .project-title {
				margin: 0;
				color: rgb(var(--black));
			}
			.post-date {
				color: rgb(var(--gray));
				font-size: 0.85em;
			}
			.post-desc, .project-desc {
				color: rgb(var(--gray));
				font-size: 0.9em;
				margin: 0.2em 0 0;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="hero">
				<h1>Paul X</h1>
				<p>{SITE_DESCRIPTION}</p>
	
			</div>

			{projects.length > 0 && (
				<section>
					<h2>Featured Projects</h2>
					<ul>
						{projects.map((project) => (
							<li>
								<div class="project-header">
									<a href={`/projects/${project.id}/`}>
										<h4 class="project-title">{project.data.title}</h4>
									</a>
									{iframeDemos.has(project.id) && (
										<>
											<span class="dot-sep">·</span>
											<a href={`/demos/${project.id}/`} class="demo-link">Demo</a>
										</>
									)}
									{externalDemoUrl.has(project.id) && (
										<>
											<span class="dot-sep">·</span>
											<a href={externalDemoUrl.get(project.id)} class="demo-link" target="_blank" rel="noopener noreferrer">Demo</a>
										</>
									)}
									{'release' in project.data && project.data.release && (
										<>
											<span class="dot-sep">·</span>
											<a href={project.data.release} class="demo-link" target="_blank" rel="noopener">Release</a>
										</>
									)}
								</div>
								<a href={`/projects/${project.id}/`}>
									<p class="project-desc">{project.data.description}</p>
								</a>
							</li>
						))}
					</ul>
					<a class="see-all" href="/projects/">See all projects &rarr;</a>
				</section>
			)}

			{posts.length > 0 && (
				<section>
					<h2>Featured Posts</h2>
					<ul>
						{posts.map((post) => (
							<li>
								<a href={`/blog/${post.id}/`}>
									<h4 class="post-title">{post.data.title}</h4>
									{post.data.description && (
										<p class="post-desc">{post.data.description}</p>
									)}
									<p class="post-date"><FormattedDate date={post.data.pubDate} /></p>
								</a>
							</li>
						))}
					</ul>
					<a class="see-all" href="/blog/">See all posts &rarr;</a>
				</section>
			)}
		</main>
		<Footer />
	</body>
</html>
