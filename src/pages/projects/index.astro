---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';

const githubProjects = await getCollection('projects');
const externalProjects = await getCollection('externalProjects');

const projects = [...githubProjects, ...externalProjects].sort(
	(a, b) => a.data.sortOrder - b.data.sortOrder,
);

const iframeDemos = new Set((await getCollection('demos')).map((d) => d.id));
const externalDemoUrl = new Map(
	externalProjects.map((p) => [p.id, p.data.demoUrl]),
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Projects - ${SITE_TITLE}`} description="Portfolio of projects." />
		<style>
			main {
				max-width: min(1080px, calc(100% - 2em));
			}
			ul {
				display: flex;
				flex-wrap: wrap;
				gap: 2rem;
				list-style-type: none;
				margin: 0;
				padding: 0;
			}
			ul li {
				width: calc(50% - 1rem);
				box-sizing: border-box;
				padding: 1em;
				border: 1px solid rgb(var(--gray-light));
				border-radius: 8px;
				transition: 0.2s ease;
			}
			ul li:hover {
				box-shadow: var(--box-shadow);
			}
			ul li a {
				display: block;
				text-decoration: none;
			}
			.project-header {
				display: flex;
				align-items: baseline;
				gap: 0.5em;
				flex-wrap: wrap;
			}
			.dot-sep {
				color: rgb(var(--gray));
			}
			.demo-link {
				color: var(--accent);
				text-decoration: underline;
				font-size: 1.1em;
			}
			.demo-link:hover {
				opacity: 0.8;
			}
			.title {
				margin: 0;
				color: rgb(var(--black));
				line-height: 1.2;
			}
			.description {
				margin: 0.5em 0 0;
				color: rgb(var(--gray));
				font-size: 0.9em;
			}
			.tags {
				display: flex;
				gap: 0.4em;
				flex-wrap: wrap;
				margin-top: 0.5em;
			}
			.tag {
				background: rgb(var(--gray-light));
				color: rgb(var(--gray-dark));
				padding: 0.15em 0.5em;
				border-radius: 4px;
				font-size: 0.8em;
			}
			@media (max-width: 720px) {
				ul li {
					width: 100%;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<h1>Projects</h1>
			<section>
				<ul>
					{
						projects.map((project) => (
							<li>
								<div class="project-header">
									<a href={`/projects/${project.id}/`}>
										<h4 class="title">{project.data.title}</h4>
									</a>
									{iframeDemos.has(project.id) && (
										<>
											<span class="dot-sep">·</span>
											<a href={`/demos/${project.id}/`} class="demo-link">Demo</a>
										</>
									)}
									{externalDemoUrl.has(project.id) && (
										<>
											<span class="dot-sep">·</span>
											<a href={externalDemoUrl.get(project.id)} class="demo-link" target="_blank" rel="noopener noreferrer">Demo</a>
										</>
									)}
									{'release' in project.data && project.data.release && (
										<>
											<span class="dot-sep">·</span>
											<a href={project.data.release} class="demo-link" target="_blank" rel="noopener">Release</a>
										</>
									)}
								</div>
								<a href={`/projects/${project.id}/`}>
									<p class="description">{project.data.description}</p>
									{project.data.tags.length > 0 && (
										<div class="tags">
											{project.data.tags.map((tag) => (
												<span class="tag">{tag}</span>
											))}
										</div>
									)}
								</a>
							</li>
						))
					}
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>
