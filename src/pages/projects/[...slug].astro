---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import ProjectPage from '../../layouts/ProjectPage.astro';

export async function getStaticPaths() {
	const githubProjects = await getCollection('projects');
	const externalProjects = await getCollection('externalProjects');
	return [...githubProjects, ...externalProjects].map((project) => ({
		params: { slug: project.id },
		props: project,
	}));
}
type Props =
	| CollectionEntry<'projects'>
	| CollectionEntry<'externalProjects'>;

const project = Astro.props;
const { Content } = await render(project);
---

<ProjectPage {...project.data}>
	<Content />
</ProjectPage>
